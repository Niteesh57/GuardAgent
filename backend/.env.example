# ==============================================================
# Auth0 — Core
# ==============================================================
# Your Auth0 tenant domain (no https://)
AUTH0_DOMAIN=your-tenant.us.auth0.com

# API Identifier set in Auth0 Dashboard → Applications → APIs
AUTH0_AUDIENCE=https://cloud-agent-api

# Management API (for Token Vault lookups)
# Create a Machine-to-Machine app in Auth0 with Management API access
AUTH0_MGMT_CLIENT_ID=your-m2m-client-id
AUTH0_MGMT_CLIENT_SECRET=your-m2m-client-secret
AUTH0_MGMT_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# ==============================================================
# Groq
# ==============================================================
GROQ_API_KEY=gsk_your_groq_api_key_here


# ==============================================================
# Twilio
# ==============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ==============================================================
# Server
# ==============================================================
PORT=8000
FRONTEND_URL=http://localhost:3000
LOG_FILE=logs/actions.jsonl
